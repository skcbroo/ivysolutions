# ─── Postgres ─────────────────────────────────────────────────────
POSTGRES_DB=ivysolutions
POSTGRES_USER=admin
POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE

# ─── App ──────────────────────────────────────────────────────────
# JWT_SECRET: gere com: openssl rand -base64 48
JWT_SECRET=TROQUE_POR_UMA_CHAVE_LONGA_E_ALEATORIA_MIN_32_CHARS
PUBLIC_URL=https://www.ivysolutions.com.br
ALLOW_REGISTRATION=false

# ─── Bootstrap admin (criado no primeiro boot se DB vazio) ────────
ADMIN_EMAIL=analista@ivy.com
ADMIN_PASSWORD=TROQUE_NO_PRIMEIRO_LOGIN
ADMIN_NOME=Analista

# ─── Block 3: análise de comunicados via Claude ───────────────────
BLOCK3_ENABLED=true
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# ─── Block 4: buscas internacionais (OpenSanctions) ───────────────
BLOCK4_ENABLED=false
OPENSANCTIONS_API_KEY=

# ─── SMTP (envio de leads) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
LEAD_TO_EMAIL=
LEAD_FROM_EMAIL=
