# Postgres
DATABASE_URL=postgresql://admin:senha123@localhost:5432/ivysolutions

# Servidor
PORT=3002
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# SMTP Gmail
# Use uma App Password (https://myaccount.google.com/apppasswords), não a
# senha normal da conta. 2FA precisa estar ativo na conta Google.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
LEAD_FROM_EMAIL=seuemail@gmail.com
LEAD_TO_EMAIL=operacoes@ivy.com.br

# OSINT (área interna de analistas)
# JWT_SECRET deve ter 16+ chars. Em prod, gere com: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-please-32ch!
# Tempo de vida do token (ex: 12h, 7d, 60m)
JWT_TTL=12h
# Permite registro público de novos usuários via /api/auth/register.
# Em prod, deixe vazio (admins criam usuários via /osint/admin/usuarios).
ALLOW_REGISTRATION=

# Bootstrap do primeiro admin.
# No primeiro boot do backend, se nenhum admin ativo existir no DB,
# cria um usuário admin com estes dados (must_change_password=true).
# Idempotente: rodadas seguintes são no-op se já houver admin.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NOME=
